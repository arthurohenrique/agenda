# Valores públicos; seguros para bundle do navegador.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=public-anon-key-from-supabase-status
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Somente servidor. Nunca prefixar com NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=service-role-key-for-local-jobs-only
BOOKING_TOKEN_PEPPER=replace-with-at-least-32-random-characters
TRUSTED_CLIENT_IP_HEADER=x-real-ip

# Worker interno. Provedor real fica para configuração do ambiente.
NOTIFICATION_WORKER_SECRET=replace-with-at-least-32-random-characters
NOTIFICATION_MODE=dry-run
NOTIFICATION_WEBHOOK_URL=https://notifications.example.com/events
NOTIFICATION_WEBHOOK_SECRET=replace-with-provider-secret
